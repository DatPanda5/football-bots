# Footy Bot (Discord name: footy_bot)
# Copy to .env and set your values.
# You can use the same names as Blue Frontier if running on the same machine (different tokens per bot).

FOOTY_BOT_TOKEN=your_footy_bot_token_here
FOOTY_BOT_CLIENT_ID=your_application_client_id_here
FOOTY_BOT_GUILD_ID=your_discord_server_id_here

# Channel where "Prediction Locked In!" embeds are posted
FOOTY_BOT_PREDICTIONS_CHANNEL_ID=123456789012345678

# Optional: use DISCORD_TOKEN, CLIENT_ID, GUILD_ID, PREDICTIONS_CHANNEL_ID if you prefer
