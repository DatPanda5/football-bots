# The Blue Frontier Committee — Discord Bot
# Copy to .env and fill in real values. Get them from:
# https://discord.com/developers/applications → your app → Bot (token) & OAuth2 (client id)
# Server (guild) ID: enable Developer Mode in Discord, right‑click your server → Copy Server ID

DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_application_client_id_here
GUILD_ID=your_discord_server_id_here

# Optional: MOD role ID. Users with this role can use /final, /resetleaderboard, and MOD view in /listpredictions.
# MOD_ROLE_ID = test server (or default). BLUE_FRONTIER_MOD_ROLE_ID = used only in The Blue Frontier server.
# MOD_ROLE_ID=1473364894471557291
# BLUE_FRONTIER_MOD_ROLE_ID=1306013527961501812

# v3.0 — Channel for prediction confirmations and auto result embeds
# PREDICTIONS_CHANNEL_ID=123456789012345678
# RESULTS_CHANNEL_ID=123456789012345678
# If RESULTS_CHANNEL_ID is unset, auto result checker uses PREDICTIONS_CHANNEL_ID.

# v3.0 — SportRadar API key for auto result checker (optional; leave unset to use /final only)
# SPORTRADAR_KEY=your_sportradar_api_key_here

# Optional: only in The Blue Frontier server, restrict prediction commands to specific channels.
# BLUE_FRONTIER_GUILD_ID = The Blue Frontier server ID (right‑click server name → Copy Server ID).
# ALLOWED_PREDICTION_CHANNEL_IDS = comma-separated channel IDs (e.g. score-predictions channel). Other servers (e.g. test) are unrestricted.
# BLUE_FRONTIER_GUILD_ID=your_blue_frontier_server_id_here
# ALLOWED_PREDICTION_CHANNEL_IDS=1306046468846522378

# Optional: persistent storage (e.g. Railway volume). See DEPLOY.md to keep predictions across redeploys.
# DATA_DIR=/data
# One-time restore: set to base64 of a predictions.db backup (then remove after first successful start).
# RESTORE_DB_BASE64=
# Force re-run seed from seed-predictions.json (merge/update). Set to 1, deploy, then remove.
# SEED_PREDICTIONS=1
