# Blue Frontier Lab — local testing (DATPANDA BOT TESTING server)
# Copy to .env.lab in this folder and fill in your LAB bot credentials from Discord Developer Portal.
# Production uses Railway variables; never put production token here.
#
# Public reference (safe to share; not secrets):
#   Application ID / CLIENT_ID: 1479514028450775082 — lab app's ID, appears in OAuth URLs.
#   Invite (use scope bot+applications.commands so / commands show): https://discord.com/oauth2/authorize?client_id=1479514028450775082&permissions=8545400010046705&integration_type=0&scope=bot%20applications.commands
#   DATPANDA BOT TESTING Server ID (GUILD_ID): 609194510660009995 — guild IDs are visible with Developer Mode.
#   In the lab app: Bot → Privileged Gateway Intents → turn ON "Message Content Intent" (or the bot will crash with "Used disallowed intents").

DISCORD_TOKEN=your_lab_bot_token_here
CLIENT_ID=1479514028450775082
GUILD_ID=609194510660009995

# Optional: MOD role on the lab server for /final, /resetleaderboard
# MOD_ROLE_ID=

# Optional: channel IDs for predictions/results on lab server.
# If unset you'll see: "No RESULTS_CHANNEL_ID / PREDICTIONS_CHANNEL_ID in .env — auto result checker disabled."
# That's fine for lab; you can still use /final manually. To enable auto checker, set one or both (right‑click channel → Copy ID in Discord).
# PREDICTIONS_CHANNEL_ID=
# RESULTS_CHANNEL_ID=
